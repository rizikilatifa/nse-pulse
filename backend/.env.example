# NSE Pulse Backend Environment Variables

# App Settings
APP_NAME=NSE Pulse
APP_VERSION=1.0.0
DEBUG=false

# Database (SQLite)
DATABASE_URL=sqlite+aiosqlite:///./nse_pulse.db

# Sentiment Model
USE_FINBERT=true
FINBERT_MODEL=ProsusAI/finbert
MODEL_CACHE_DIR=./model_cache

# Scraping
SCRAPE_TIMEOUT=30
MAX_ARTICLES_PER_SOURCE=50

# Twitter API (optional - for Twitter scraper)
# Get your bearer token from https://developer.twitter.com
TWITTER_BEARER_TOKEN=
